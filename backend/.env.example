# Application Settings
APP_NAME="Industrial Safety Intelligence Platform API"
DEBUG=True
API_V1_STR="/api/v1"

# Database Settings
# Using SQLite locally. The file will be placed in the backend/data/ directory.
DATABASE_URL="sqlite:///./data/safety_platform.db"

# AI & LLM Settings
# Replace with your OpenAI or other LLM provider keys
OPENAI_API_KEY="your-openai-api-key-here"
GEMINI_API_KEY="your-gemini-api-key-here"

# RAG Settings
FAISS_INDEX_PATH="./data/faiss_index"
VECTOR_DB_DIMENSION=1536 # Default for text-embedding-3-small / text-embedding-ada-002
